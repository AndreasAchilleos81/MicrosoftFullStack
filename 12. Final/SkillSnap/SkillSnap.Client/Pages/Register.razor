@page "/register"
@using Shared.Models.DTO
@using SkillSnap.Client.Services
@inject AuthService AuthService;
<h3>Register</h3>

@if (successfulRegistration == false)
{
    <div class="registration-container">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <div class="form-group">
            <label>Email:</label>
            <input type="email" @bind="registration.Email" class="form-control" />
        </div>

        <div class="form-group">
            <label>Username:</label>
            <input type="text" @bind="registration.UserName" class="form-control" />
        </div>

        <div class="form-group">
            <label>Password:</label>
            <input type="password" @bind="registration.Password" class="form-control" />
        </div>

        <div class="form-group">
            <label>Confirm Password:</label>
            <input type="password" @bind="registration.ConfirmPassword" class="form-control" />
        </div>

        <button class="btn btn-primary" @onclick="() => HandleSubmit()">Register</button>
    </div>
}
else if (failedToRegister)
{
    <div class="alert alert-danger">Failed to register. Please try again.</div>
}
else
{
    <div>Successfull Registration!!</div>
}


@code {

    private Registration registration = new();
    private string errorMessage;
    private bool successfulRegistration = false;
    private bool failedToRegister = false;

    private async Task HandleSubmit()
    {
        errorMessage = string.Empty;

        // Manual Validation Logic
        if (string.IsNullOrWhiteSpace(registration.Email))
        {
            errorMessage = "Email is required.";
            return;
        }

        if (registration.Password != registration.ConfirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        // Logic to call your API or Service
        Console.WriteLine($"Registering: {registration.Email}");
        if (await AuthService.Register(registration))
        {
            successfulRegistration = true;
        }
        else
        {
            failedToRegister = true;
        }
    }
}
