@page "/projects/{projectId:int}"
@using Shared.Models
@using Shared.Models.DTO
@using SkillSnap.Client.Services
@using System.Linq;
@inject ProjectService ProjectService
@inject UserSessionService UserSessionState
@inject IJSRuntime JS

<h3>Edit Project</h3>

@if (Project is null || Project.value is null)
{
    <p>Loading...</p>
}
else
{
    <div class="project-edit-container">

        <div class="project-card">
            <h3 class="section-title">Edit Project</h3>

            <EditForm Model="Project" OnValidSubmit="SaveProject">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group">
                    <label>Project Id</label>
                    <input class="form-control" value="@Project.value.Id" readonly />
                </div>

                <div class="form-group">
                    <label>Title</label>
                    <InputText class="form-control" @bind-Value="Project.value.Title" />
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <InputTextArea class="form-control" @bind-Value="Project.value.Description" />
                </div>

                <div class="form-group">
                    <label>Image URL</label>
                    <InputText class="form-control" @bind-Value="Project.value.ImageUrl" />
                </div>

                @if (!string.IsNullOrWhiteSpace(Project.value.ImageUrl))
                {
                    <img src="@Project.value.ImageUrl" class="image-preview" />
                }

                <button type="submit" class="btn btn-primary mt-3">Save</button>
            </EditForm>
        </div>

        <h4 class="section-title">Portfolio Users</h4>

        @for (int i = 0; i < Project.value.PortfolioUsers.Count; i++)
        {
            var user = Project.value.PortfolioUsers[i];

            <div class="user-card compact-card">

                <div class="user-header">
                    <img src="@user.ProfilePictureUrl" class="user-thumb" />

                    <div class="user-main">
                        <InputText class="form-control form-control-sm"
                                   @bind-Value="user.Name"
                                   placeholder="Name" />

                        <InputTextArea class="form-control form-control-sm bio-box"
                                       @bind-Value="user.Bio"
                                       placeholder="Short bio..." />
                    </div>

                    <button type="button"
                            class="btn btn-danger btn-sm btn-remove"
                            @onclick="() => RemoveUser(i)">
                        ✕
                    </button>
                </div>

                <div class="skills-section">
                    <label>Skills</label>

                    <div class="skills-list">
                        @foreach (var skill in user.Skills)
                        {
                            <span class="skill-tag">
                                @skill.Name
                                <button type="button" class="remove-skill"
                                        @onclick="() => RemoveSkill(user, skill)">
                                    ×
                                </button>
                            </span>
                        }
                    </div>

                    <div class="add-skill-row">
                        <InputText @bind-Value="newSkill"
                                   class="form-control form-control-sm"
                                   placeholder="Add skill..." />
                        <InputText @bind-Value="newSkillLevel"
                                   class="form-control form-control-sm"
                                   placeholder="evel..." />

                        <button class="btn btn-primary btn-sm"
                                @onclick="() => AddSkill(user)">
                            Add
                        </button>
                    </div>
                </div>

                <details class="advanced-details">
                    <summary>More Details</summary>

                    <div class="form-group mt-2">
                        <label>Profile Picture URL</label>
                        <InputText class="form-control form-control-sm"
                                   @bind-Value="user.ProfilePictureUrl" />
                    </div>

                    @if (!string.IsNullOrWhiteSpace(user.ProfilePictureUrl))
                    {
                        <img src="@user.ProfilePictureUrl" class="image-preview-small" />
                    }
                </details>

            </div>

        }

        <button class="btn btn-secondary btn-add" @onclick="AddUser">
            Add Portfolio User
        </button>
    </div>
}

@code {

    [Parameter]
    public int ProjectId { get; set; }

    public ProjectDto Project { get; set; } = new();

    private DotNetObjectReference<ProjectDetails>? _objRef;

    private string newSkill = string.Empty;
    private string newSkillLevel = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // Load the project using the ProjectId
        Project = await ProjectService.GetProjectAsync(ProjectId);
        await UserSessionState.SetCurrentProjectId(Project.value.Id);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("skillSnap.onExit", DotNetObjectReference.Create(this));
        }
    }

    [JSInvokable]
    public async Task ClearLocalStorage()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "projectId");
    }

    public void Dispose()
    {
        _objRef?.Dispose();
    }

    void AddUser()
    {
        Project.value.PortfolioUsers.Add(new PortfolioUser());
    }

    void RemoveUser(int index)
    {
        Project.value.PortfolioUsers.RemoveAt((index - 1));
    }

    void AddSkill(PortfolioUser user)
    {
        if (!string.IsNullOrWhiteSpace(newSkill))
        {
            var skillToAdd = new Skill() { 
                Name = this.newSkill.Trim(), 
                Level = newSkillLevel 
            };
            
            skillToAdd.PortfolioUsers = new List<PortfolioUser> { user };
            user.Skills.Add(skillToAdd);
            newSkill = string.Empty;
            newSkillLevel = string.Empty;
        }
    }

    void RemoveSkill(PortfolioUser user, Skill skill)
    {
        user.Skills.Remove(skill);
    }

    private async Task SaveProject()
    {
        await ProjectService.UpdateProject(Project);
        await UserSessionState.RemoveCurrentProjectId();
    }
}